{
	"$schema": "../../.claude/skills/design-config/json-schemas/current.json",
	"version": "1.0.0",
	"project": {
		"name": "spencerbeggs/jsonc-effect",
		"type": "package",
		"repository": "https://github.com/spencerbeggs/jsonc-effect",
		"maintainer": "C. Spencer Beggs"
	},
	"paths": {
		"designDocs": ".claude/design",
		"plans": ".claude/plans",
		"skills": ".claude/skills",
		"context": "CLAUDE.md"
	},
	"modules": {
		"jsonc-effect": {
			"path": ".",
			"designDocsPath": ".claude/design/jsonc-effect",
			"categories": ["architecture", "performance", "testing"],
			"maintainer": "C. Spencer Beggs",
			"userDocs": {
				"readme": "README.md",
				"repoDocs": null,
				"siteDocs": null
			}
		}
	},
	"skills": {
		"baseNamespace": "/",
		"enabled": [
			"design-init",
			"design-validate",
			"design-update",
			"design-sync",
			"design-review",
			"design-audit",
			"design-search",
			"design-report",
			"design-archive",
			"design-prune",
			"design-config",
			"plan-validate",
			"plan-create",
			"plan-list"
		]
	},
	"quality": {
		"designDocs": {
			"maxLineLength": 120,
			"requireFrontmatter": true,
			"requireTOC": true,
			"minSections": ["Overview", "Current State", "Rationale"]
		},
		"context": {
			"rootMaxLines": 500,
			"childMaxLines": 300,
			"requireDesignDocPointers": true
		}
	},
	"integration": {
		"ci": {
			"enabled": false,
			"validateOnPR": false,
			"syncOnMerge": false
		},
		"git": {
			"trackDesignDocs": true,
			"requireReviewForChanges": false
		}
	}
}
